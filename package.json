{
  "name": "seoul-orthopedic",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "python3 -m http.server 3000",
    "start": "npm run dev",
    "build": "node ./scripts/validate-static-site.js",
    "build:mobile": "npm run build && node ./scripts/build-mobile-app.js",
    "android:sync": "npm run build:mobile && npx cap sync android",
    "android:debug": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "android:open": "npx cap open android",
    "lint": "node --check ./scripts/validate-static-site.js && node ./scripts/validate-static-site.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1"
  }
}
